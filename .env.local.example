DATABASE_URL=postgresql://app:password@localhost:5432/appdb

# Firebase — frontend config (from Firebase console → Project settings → Your apps → Web app)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=

# Firebase — backend service account (from Firebase console → Project settings → Service accounts → Generate new private key)
# Used by the server (auth middleware) and by Cypress (cypress-firebase plugin)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Cypress E2E — UID of a real Firebase user to run tests as (find it in Firebase console → Authentication → Users)
CYPRESS_TEST_USER_ID=

# PORT=5000
