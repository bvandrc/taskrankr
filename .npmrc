# Prevent Cypress from downloading its binary during `npm install`.
# Uses the correct npm config key (lowercase) that Cypress recognises.
# NOTE: this only skips the binary download, not the npm package itself.
# Replit's publish build environment also blocks the npm-run-path package
# (a transitive dep of Cypress) at the registry proxy level, so the
# binary-skip alone does not fully fix the publish build — see docs/cypress-publish.md.
#
# To run E2E tests locally after a fresh install, get the binary with:
#   npx cypress install
cypress_install_binary=0
