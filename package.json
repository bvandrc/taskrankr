    "react-dom": "^18.3",
    "react-hook-form": "^7.75",
    "react-icons": "^5.6",
    "tailwind-merge": "^2.6",
    "tailwindcss": "^4.2",
    "tw-animate-css": "^1.4",
    "vite-plugin-pwa": "^1.3",
