{
  "name": "taskrankr",
  "author": {
    "name": "Blake Vandercar",
    "email": "bvandercar@outlook.com"
  },
  "version": "0.2.4",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "__c1": "====================[ Build & Development ]======================",
    "dev": "cross-env NODE_ENV=development tsx server/index.ts",
    "build": "tsx script/build.ts",
    "start": "cross-env NODE_ENV=production node dist/index.cjs",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "__c2": "====================[ Linting & Type Checking ]==================",
    "check": "npm run lint && npm run ts:check && npm run cy:ts:check",
    "format": "npx biome check . --fix",
    "lint": "npx biome check .",
    "lint:fix": "npm run format",
    "ts:check": "tsc",
    "__c3": "====================[ Cypress Testing ]==========================",
    "test:e2e:guest": "npm run cy:run:guest",
    "test:e2e:user": "npm run cy:run:user",
    "cy:ts:check": "tsc  --project cypress/tsconfig.json",
    "cy:run:all": "npm run cy:run:user ; npm run cy:run:guest",
    "cy:run:user": "cypress run --env userMode=USER",
    "cy:run:guest": "cypress run --env userMode=GUEST",
    "cy:run:user:video": "npm run cy:run:user -- --config video=true",
    "cy:run:guest:video": "npm run cy:run:guest -- --config video=true",
    "cy:open:user": "cypress open --env userMode=USER",
    "cy:open:guest": "cypress open --env userMode=GUEST"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3",
    "@dnd-kit/sortable": "^10.0",
    "@dnd-kit/utilities": "^3.2",
    "@hookform/resolvers": "^3.10",
    "@jridgewell/trace-mapping": "^0.3",
    "@radix-ui/react-alert-dialog": "^1.1",
    "@radix-ui/react-checkbox": "^1.3",
    "@radix-ui/react-dialog": "^1.1",
    "@radix-ui/react-dropdown-menu": "^2.1",
    "@radix-ui/react-label": "^2.1",
    "@radix-ui/react-popover": "^1.1",
    "@radix-ui/react-select": "^2.1",
    "@radix-ui/react-separator": "^1.1",
    "@radix-ui/react-slot": "^1.2",
    "@radix-ui/react-switch": "^1.2",
    "@radix-ui/react-toast": "^1.2",
    "@radix-ui/react-toggle": "^1.1",
    "@radix-ui/react-tooltip": "^1.2",
    "@tailwindcss/vite": "^4.2",
    "@tanstack/react-query": "^5.60",
    "@ts-rest/core": "^3.52",
    "@ts-rest/express": "^3.52",
    "@ts-rest/react-query": "^3.52",
    "@types/connect-pg-simple": "^7.0",
    "@types/memoizee": "^0.4",
    "@types/passport": "^1.0",
    "class-variance-authority": "^0.7",
    "clsx": "^2.1",
    "connect-pg-simple": "^10.0",
    "date-fns": "^3.6",
    "drizzle-orm": "^0.39",
    "drizzle-zod": "^0.7",
    "es-toolkit": "^1.44",
    "express": "^4.22",
    "express-session": "^1.19",
    "framer-motion": "^11.18",
    "is-standalone-pwa": "^0.1",
    "lucide-react": "^0.453.0",
    "memoizee": "^0.4",
    "memorystore": "^1.6",
    "nanoid": "^5.1",
    "openid-client": "^6.8",
