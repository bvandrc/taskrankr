{
  "name": "taskrankr",
  "author": {
    "name": "Blake Vandercar",
    "email": "bvandercar@outlook.com"
  },
  "version": "0.2.5",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "__c0": "====================[ Build & Development ]======================",
    "local:db:up": "docker compose up -d",
    "local:db:down": "docker compose down",
    "build": "tsx script/build.ts",
    "dev": "cross-env NODE_ENV=development tsx server/index.ts",
    "prod:preview": "cross-env NODE_ENV=production IS_PROD=true node dist/index.cjs",
    "local:preview": "cross-env NODE_ENV=development node --env-file-if-exists=.env.local dist/index.cjs",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "__c1": "====================[ Linting & Type Checking ]==================",
    "check": "npm run ts:check && npm run cy:ts:check && npm run lint",
    "format": "npx biome check . --fix",
    "lint": "npx biome check .",
    "lint:fix": "npm run format",
    "ts:check": "tsc",
    "__c2": "====================[ Cypress Testing ]==========================",
    "test:e2e:guest": "npm run cy:run:guest",
    "test:e2e:user": "npm run cy:run:user",
    "cy:ts:check": "tsc  --project cypress/tsconfig.json",
    "cy:run:all": "npm run cy:run:user ; npm run cy:run:guest",
    "cy:run:user": "cypress run --env userMode=USER",
    "cy:run:guest": "cypress run --env userMode=GUEST",
    "cy:run:user:video": "npm run cy:run:user -- --config video=true",
    "cy:run:guest:video": "npm run cy:run:guest -- --config video=true",
    "cy:open:user": "cypress open --env userMode=USER",
    "cy:open:guest": "cypress open --env userMode=GUEST"
  },
  "dependencies": {
    "@dnd-kit/core": "^6",
    "@dnd-kit/sortable": "^10",
    "@dnd-kit/utilities": "^3",
    "@hookform/resolvers": "^5",
    "@jridgewell/trace-mapping": "^0.3",
    "@radix-ui/react-alert-dialog": "^1",
    "@radix-ui/react-checkbox": "^1",
    "@radix-ui/react-dialog": "^1",
    "@radix-ui/react-dropdown-menu": "^2",
    "@radix-ui/react-label": "^2",
    "@radix-ui/react-popover": "^1",
    "@radix-ui/react-select": "^2",
    "@radix-ui/react-separator": "^1",
    "@radix-ui/react-slot": "^1",
    "@radix-ui/react-switch": "^1",
    "@radix-ui/react-toast": "^1",
    "@radix-ui/react-toggle": "^1",
    "@radix-ui/react-tooltip": "^1",
    "@tailwindcss/typography": "^0.5",
    "@tailwindcss/vite": "^4",
    "@ts-rest/core": "^3",
    "@ts-rest/express": "^3",
    "@types/connect-pg-simple": "^7",
    "@types/memoizee": "^0.4",
    "@types/passport": "^1",
    "class-variance-authority": "^0.7",
    "clsx": "^2",
    "connect-pg-simple": "^10",
    "date-fns": "^4",
    "drizzle-orm": "^0.45",
    "drizzle-zod": "^0.7",
    "es-toolkit": "^1",
    "express": "^4",
    "express-session": "^1",
    "framer-motion": "^12",
    "is-standalone-pwa": "^0.1",
    "lucide-react": "^1",
    "memoizee": "^0.4",
    "memorystore": "^1",
    "nanoid": "^5",
    "openid-client": "^6",
    "passport": "^0.7",
    "pg": "^8",
    "react": "^18",
    "react-day-picker": "^9",
    "react-dom": "^18",
    "react-hook-form": "^7",
    "react-icons": "^5",
    "tailwind-merge": "^3",
    "tailwindcss": "^4",
    "tw-animate-css": "^1",
    "vite-plugin-pwa": "^1",
    "wouter": "^3",
    "ws": "^8",
    "zod": "^3",
    "zod-validation-error": "^5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.13",
    "@replit/vite-plugin-cartographer": "^0.5",
    "@replit/vite-plugin-dev-banner": "^0.1",
    "@replit/vite-plugin-runtime-error-modal": "^0.0",
    "@types/express": "4",
    "@types/express-session": "^1",
    "@types/node": "24",
