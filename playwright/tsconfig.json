{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "types": ["node"],
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "strict": true,
    "paths": {
      "@test/support/*": ["./support/*"],
      "~/client*": ["../client/src/*"],
      "~/shared/*": ["../shared/*"],
      "@/*": ["../client/src/*"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["../node_modules"]
}
